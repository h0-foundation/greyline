{
	"name": "greyline",
	"private": true,
	"version": "0.1.0",
	"description": "Privacy-first, offline-first local travel planning application",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host 127.0.0.1",
		"build": "vite build",
		"preview": "vite preview --host 127.0.0.1",
		"start": "node build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"setup": "pnpm install && pnpm migrate && pnpm seed",
		"seed": "tsx scripts/seed-db.ts",
		"migrate": "tsx scripts/migrate.ts",
		"build:countries": "tsx scripts/build-country-data.ts",
		"clean": "rm -rf build .svelte-kit data/greyline.db data/greyline.db-wal data/greyline.db-shm",
		"reset": "pnpm clean && pnpm migrate && pnpm seed"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.0.0",
		"@types/better-sqlite3": "^7.6.8",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.0.0",
		"tsx": "^4.7.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"argon2": "^0.41.0",
		"better-sqlite3": "^11.0.0",
		"maplibre-gl": "^5.18.0",
		"ofetch": "^1.4.0",
		"pmtiles": "^4.4.0",
		"uuid": "^11.0.0"
	},
	"license": "AGPL-3.0-only",
	"engines": {
		"node": ">=20.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"argon2",
			"better-sqlite3",
			"esbuild"
		]
	}
}
