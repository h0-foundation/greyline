{
  "name": "greyline",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Privacy-first, offline-first local travel companion. No account, no cloud, no tracking.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed-db.ts",
    "build:countries": "tsx scripts/build-country-data.ts",
    "build:data": "tsx scripts/build-data.ts",
    "build:dossier": "tsx scripts/build-dossier.ts",
    "build:advisories": "tsx scripts/build-advisories.ts",
    "build:trip-data": "tsx scripts/build-trip-data.ts",
    "e2e": "pnpm build && playwright test",
    "e2e:headed": "playwright test --headed",
    "setup": "pnpm install && pnpm migrate && pnpm seed"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "argon2": "^0.41.0",
    "better-sqlite3": "^11.0.0",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "cmdk": "^1.1.1",
    "lucide-react": "latest",
    "maplibre-gl": "^5.18.0",
    "motion": "latest",
    "next": "16.2.6",
    "next-themes": "latest",
    "ofetch": "^1.4.0",
    "pmtiles": "^4.4.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-map-gl": "^8.1.0",
    "tailwind-merge": "latest",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.7.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  },
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
