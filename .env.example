# Greyline Configuration
# No environment variables are required for basic operation.
# All data is stored locally and all APIs are disabled by default.

# Server binding (default: localhost only)
HOST=127.0.0.1
PORT=5173

# Tor SOCKS5 proxy (optional, for routing API calls through Tor)
# TOR_SOCKS_HOST=127.0.0.1
# TOR_SOCKS_PORT=9050
